# Copy this file to `.env` and fill in your own values.
# Nothing here is required for the core framework -- only for the
# optional local assistant / fine-tuning / RAG bits.

# Ollama (local LLM)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Qdrant (used by rag/)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=neural_kernel_code

# HF token if you want to download gated models for fine-tuning
HF_TOKEN=
