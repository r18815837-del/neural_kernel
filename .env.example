# Neural Kernel - Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git!

# --- LLM Provider ---
NK_LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here

NK_LLM_MODEL=gpt-4o-mini
NK_LLM_FAST_MODEL=gpt-4o-mini
NK_LLM_SMART_MODEL=gpt-4o
NK_LLM_TEMPERATURE=0.3
NK_LLM_MAX_TOKENS=4096
NK_LLM_TIMEOUT=60
NK_LLM_RETRY_ATTEMPTS=3

# --- JWT Authentication ---
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
NK_JWT_SECRET=change-me-to-a-random-secret
NK_JWT_ALGORITHM=HS256
NK_JWT_EXPIRY_HOURS=24

# --- Database ---
NK_DB_PATH=data/neural_kernel.db

# --- API Server ---
NK_API_HOST=0.0.0.0
NK_API_PORT=8000
NK_API_DEBUG=false
NK_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- GPU (optional) ---
# pip install cupy-cuda12x
# NK_DEVICE=cuda
